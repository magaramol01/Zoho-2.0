{
  "name": "@zoho-power-grid/desktop",
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.zoho.powergrid",
    "productName": "Zoho Power Grid",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../web/public/logo.svg"
    },
    "files": [
      "main.js",
      "package.json",
      "../api/dist/**/*",
      "../api/package.json",
      "../api/node_modules/**/*",
      "../web/.next/standalone/**/*",
      "../web/public/**/*",
      "../web/.next/static/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^10.0.1",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^8.0.5"
  }
}
