{
  "name": "zoho-sprints-power-grid",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @zoho-power-grid/api --filter @zoho-power-grid/web dev",
    "dev:api": "pnpm --filter @zoho-power-grid/api dev",
    "dev:web": "pnpm --filter @zoho-power-grid/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "migrate": "pnpm --filter @zoho-power-grid/api migrate",
    "seed": "pnpm --filter @zoho-power-grid/api seed",
    "dev:desktop": "concurrently \"pnpm dev\" \"pnpm --filter @zoho-power-grid/desktop start\"",
    "build:desktop": "pnpm -r build && pnpm --filter @zoho-power-grid/desktop dist"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "better-sqlite3",
      "esbuild",
      "electron",
      "electron-winstaller",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "concurrently": "^10.0.1"
  }
}
