{
  "name": "@zoho-power-grid/desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux AppImage",
    "dist:dir": "electron-builder --linux dir"
  },
  "build": {
    "appId": "com.zoho.powergrid",
    "productName": "Zoho Power Grid",
    "copyright": "Copyright © 2025 Zoho Power Grid",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icons",
      "category": "Office",
      "synopsis": "Zoho Sprints Power Grid Desktop"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../api/.deploy",
        "to": "api",
        "filter": ["**/*", "!src/**", "!scripts/**", "!*.ts", "!tsconfig*"]
      },
      {
        "from": "../web/.deploy2",
        "to": "web",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "concurrently": "^10.0.1",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^8.0.5"
  }
}
